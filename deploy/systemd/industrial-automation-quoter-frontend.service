[Unit]
Description=Industrial Automation Quoter Frontend (Preview)
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/saulordz/projects
Environment=HOME=/home/saulordz
Environment=PATH=/home/saulordz/n/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
Environment=NODE_ENV=production
ExecStart=/home/saulordz/n/bin/npm --workspace frontend run preview -- --host 0.0.0.0 --port 5173
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
